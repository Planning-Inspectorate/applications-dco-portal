{% extends "govuk/template.njk" %}

{% block head %}
    <link rel="stylesheet" href="../stylesheets/test.css"/>
	<meta name="referrer" content="origin">
{% endblock %}

{% block pageTitle %}
	DCO Application Form - {{ dcoApplicationData.caseReference }}
{% endblock %}

{% block header %}
	put the header image here
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <h1 class="govuk-heading-xl">
                DCO Application Form - {{ dcoApplicationData.caseReference }}
            </h1>
        </div>
    </div>
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-third">
            <p class="govuk-body"> Applicant First Name</p>
        </div>
        <div class="govuk-grid-column-one-third">
            <p class="govuk-body"> {{ dcoApplicationData.application.applicantAgentDetails.applicantFirstName }}</p>
        </div>
    </div>
{% endblock %}

{% block footer %}
	include any footer njk templaktes here
{% endblock %}
