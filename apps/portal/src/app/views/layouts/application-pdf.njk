{% extends "govuk/template.njk" %}

{% block head %}
    <link rel="stylesheet" href="../stylesheets/test.css"/>
	<meta name="referrer" content="origin">
{% endblock %}

{% block pageTitle %}
	DCO Application Form - {{ caseReference }}
{% endblock %}

{% block header %}
	put the header image here
{% endblock %}

{% block content %}
    {% block pageHeading %}
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-full">
                <h1 class="govuk-heading-xl">
                    DCO Application Form - {{ caseReference }}
                </h1>
            </div>
        </div>
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-half">
                <p class="govuk-body"> Applicant First Name</p>
            </div>
            <div class="govuk-grid-column-half">
                <p class="govuk-body"> {{ application.applicantAgentDetails.applicantFirstName }}</p>
            </div>
        </div>
    {% endblock %}
    {% block pageContent %}{% endblock %}
{% endblock %}

{% block footer %}
	include any footer njk templaktes here

	<script type="module" {% if cspNonce %}nonce={{ cspNonce }}{% endif %} src="/assets/js/govuk-frontend.min.js"></script>
	<script type="module" {% if cspNonce %}nonce={{ cspNonce }}{% endif %}>
		import { initAll } from '/assets/js/govuk-frontend.min.js'
		initAll()
	</script>
{% endblock %}
